# --- Hello-world sender configuration ---
# Copy to .env (and add .env to your .gitignore if outside this dir).

# Syncler test instance the bot will talk to.
SYNCLER_BASE_URL=https://63-181-3-204.sslip.io

# Where the bot's in-process broker listens. Default is fine when
# you run bot.py on the same machine as your phone scanner is testing
# against; otherwise change to your LAN IP + open the firewall.
BROKER_HOST=localhost
BROKER_PORT=8088

# Override only if the device-side reachable URL differs from the
# bind URL (e.g. behind ngrok, behind a reverse proxy).
# SENDER_BROKER_URL=https://your-tunnel.example/syncler/bootstrap

# Public URL where ../plugin/dist/plugin.bundle.js is reachable
# from the user's phone. Any CDN works (GitHub raw URL, S3 bucket,
# your own server). The bundle bytes MUST match what build.sh
# signed locally — the device verifies SHA-256.
SIGNED_BUNDLE_URL=https://your-cdn.example/hello-world.bundle.js
