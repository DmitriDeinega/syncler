DATABASE_URL=postgresql+asyncpg://syncler:syncler@localhost:5432/syncler
JWT_SECRET=change-me
PRE_LOGIN_PEPPER=change-me-too
FIREBASE_SERVICE_ACCOUNT_PATH=
# Any value other than "production" tags the FastAPI title and /health
# response as a non-prod environment (e.g. "Syncler Server DEV").
ENVIRONMENT=development

# --- Deployment (uncomment on hosts where uvicorn runs on the same
# --- box as Postgres + Redis behind a reverse proxy) ---
#
# When this is set, bare `docker compose up -d` picks up BOTH the base
# compose file AND the loopback override automatically. Without it, an
# operator who forgets the `-f docker-compose.loopback.yml` flag will
# bring the stack up on the dev ports (5433/6380) and uvicorn will
# crash-loop. See `docker-compose.loopback.yml` for the why.
#
# COMPOSE_FILE=docker-compose.yml:docker-compose.loopback.yml
#
# When COMPOSE_FILE is set, the URLs above MUST also be updated to
# match the loopback ports — uncomment in tandem:
#
# DATABASE_URL=postgresql+asyncpg://syncler:syncler@127.0.0.1:65432/syncler?ssl=disable
# REDIS_URL=redis://127.0.0.1:65379/0
